{
  "name": "zod-to-camel-case",
  "description": "Convert zod schema object keys to camel case",
  "version": "0.8.0",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/orangemug/zod-to-camel-case"
  },
  "main": "./dist/npm/index.js",
  "types": "./dist/npm/index.d.ts",
  "type": "module",
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "pnpx prettier . --check",
    "test": "vitest run --coverage",
    "test:watch": "vitest run --watch",
    "test:ci": "vitest run --coverage --reporter=junit --outputFile=test-report.junit.xml",
    "lint:format": "pnpx prettier . --write",
    "build": "pnpm run build:npm",
    "build:npm": "rollup -c rollup.config.ts --configPlugin typescript"
  },
  "exports": {
    ".": "./dist/npm/index.js"
  },
  "files": [
    "dist/npm",
    "package.json",
    "README.md"
  ],
  "devDependencies": {
    "@codecov/rollup-plugin": "^2.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@rollup/plugin-virtual": "^3.0.2",
    "@tsconfig/node22": "^22.0.2",
    "@types/yargs": "^17.0.34",
    "@vitest/coverage-v8": "^4.1.8",
    "prettier": "^3.8.4",
    "rollup": "^4.61.1",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-typescript-paths": "^1.5.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.3",
    "tsx": "^4.22.4",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.2.0",
  "engines": {
    "node": ">=20.x",
    "pnpm": ">=11"
  },
  "peerDependencies": {
    "zod": "^4.3.6"
  }
}
